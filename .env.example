# ── Database (required) ───────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://your-db-host:5432/rto_tracker
DATABASE_USER=rto
DATABASE_PASSWORD=changeme

# ── Ports (optional) ─────────────────────────────────────────────
# BACKEND_PORT=8080
# FRONTEND_PORT=8880

# ── Observability (optional — leave blank to disable) ────────────
# TEMPO_URL=http://your-tempo-host:9411
# LOKI_URL=http://your-loki-host:3100

# ── Application (optional) ──────────────────────────────────────
# APP_RATE_LIMIT_RPM=100
# APP_REGISTRATION_ENABLED=false

# ── Docker image tags (optional — used by docker-compose) ────────
# DOCKER_REGISTRY=yourdockerhubuser/
# IMAGE_TAG=latest
